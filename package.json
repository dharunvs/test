{
  "name": "branchline",
  "private": true,
  "version": "0.1.0",
  "description": "AI-native team coding platform monorepo",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:verify-scripts": "node scripts/verify-lint-scripts.mjs",
    "feature-gates:manifest": "node scripts/verify-feature-gates.mjs",
    "feature-gates:verify": "node scripts/verify-feature-gates.mjs --execute",
    "security:scan": "node scripts/scan-secrets.mjs",
    "security:audit": "pnpm audit --audit-level high",
    "bootstrap:local": "./scripts/bootstrap-local.sh",
    "full-stack:harness": "node scripts/run-full-stack-harness.mjs",
    "queues:replay-dlq": "node scripts/replay-dlq.mjs",
    "github:sandbox:smoke": "node scripts/github-sandbox-smoke.mjs",
    "kpi:pilot": "node scripts/extract-pilot-kpis.mjs",
    "mvp:pilot-flow": "node scripts/run-mvp-pilot-flow.mjs",
    "mvp:gate:staging": "node scripts/mvp-gate-staging.mjs",
    "mvp:gate:live": "node scripts/mvp-gate-live.mjs",
    "mvp:signoff:iteration": "node scripts/run-mvp-signoff-iteration.mjs",
    "e2e:web": "pnpm --filter @branchline/web-console e2e",
    "e2e:extension": "pnpm --filter branchline-vscode-extension e2e",
    "e2e": "pnpm e2e:web && pnpm e2e:extension",
    "test": "turbo run test",
    "test:scripts": "node --test scripts/tests/*.test.mjs",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "seed:live:e2e": "node scripts/seed-live-e2e.mjs",
    "live:preflight": "node scripts/check-live-prereqs.mjs",
    "e2e:web:live": "pnpm --filter @branchline/web-console e2e:live",
    "e2e:extension:live": "pnpm --filter branchline-vscode-extension e2e:live",
    "e2e:live:stack": "node scripts/run-live-e2e-tier.mjs",
    "mvp:pilot-flow:staging": "node scripts/run-mvp-pilot-flow-staging.mjs",
    "mvp:checks:staging": "node scripts/check-mvp-staging-thresholds.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript-eslint": "^8.26.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
