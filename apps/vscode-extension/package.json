{
  "name": "branchline-vscode-extension",
  "displayName": "Branchline",
  "description": "AI-native team coding coordination for VS Code",
  "version": "0.1.0",
  "publisher": "branchline",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:branchline.login",
    "onCommand:branchline.bindWorkspace",
    "onCommand:branchline.startAiTask",
    "onCommand:branchline.createHandoff",
    "onCommand:branchline.acknowledgeHandoff",
    "onCommand:branchline.viewReplay",
    "onCommand:branchline.viewTimeline",
    "onCommand:branchline.claimFileOwnership",
    "onView:branchline.timelineView",
    "onView:branchline.activityView",
    "onView:branchline.conflictsView",
    "onView:branchline.handoffsView",
    "onView:branchline.replayView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "branchline",
          "title": "Branchline",
          "icon": "resources/branchline.svg"
        }
      ]
    },
    "views": {
      "branchline": [
        {
          "id": "branchline.timelineView",
          "name": "Timeline"
        },
        {
          "id": "branchline.activityView",
          "name": "Live Activity"
        },
        {
          "id": "branchline.conflictsView",
          "name": "Conflict Center"
        },
        {
          "id": "branchline.handoffsView",
          "name": "Handoffs"
        },
        {
          "id": "branchline.replayView",
          "name": "Replay"
        }
      ]
    },
    "commands": [
      {
        "command": "branchline.login",
        "title": "Branchline: Login"
      },
      {
        "command": "branchline.bindWorkspace",
        "title": "Branchline: Bind Workspace"
      },
      {
        "command": "branchline.startAiTask",
        "title": "Branchline: Start AI Task"
      },
      {
        "command": "branchline.createHandoff",
        "title": "Branchline: Create Handoff"
      },
      {
        "command": "branchline.acknowledgeHandoff",
        "title": "Branchline: Acknowledge Handoff"
      },
      {
        "command": "branchline.viewReplay",
        "title": "Branchline: View Replay"
      },
      {
        "command": "branchline.viewTimeline",
        "title": "Branchline: View Timeline"
      },
      {
        "command": "branchline.claimFileOwnership",
        "title": "Branchline: Claim File Ownership"
      },
      {
        "command": "branchline.timeline.refresh",
        "title": "Branchline: Refresh Timeline"
      },
      {
        "command": "branchline.activity.refresh",
        "title": "Branchline: Refresh Live Activity"
      },
      {
        "command": "branchline.conflicts.refresh",
        "title": "Branchline: Refresh Conflict Center"
      },
      {
        "command": "branchline.handoffs.refresh",
        "title": "Branchline: Refresh Handoffs"
      },
      {
        "command": "branchline.replay.refresh",
        "title": "Branchline: Refresh Replay"
      },
      {
        "command": "branchline.timeline.setFilter",
        "title": "Branchline: Set Timeline Filter"
      },
      {
        "command": "branchline.conflicts.dismiss",
        "title": "Branchline: Dismiss Conflict"
      },
      {
        "command": "branchline.conflicts.openFile",
        "title": "Branchline: Open Conflict File"
      },
      {
        "command": "branchline.replay.markPosition",
        "title": "Branchline: Mark Replay Position"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "branchline.timeline.refresh",
          "when": "view == branchline.timelineView",
          "group": "navigation"
        },
        {
          "command": "branchline.activity.refresh",
          "when": "view == branchline.activityView",
          "group": "navigation"
        },
        {
          "command": "branchline.conflicts.refresh",
          "when": "view == branchline.conflictsView",
          "group": "navigation"
        },
        {
          "command": "branchline.handoffs.refresh",
          "when": "view == branchline.handoffsView",
          "group": "navigation"
        },
        {
          "command": "branchline.replay.refresh",
          "when": "view == branchline.replayView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "e2e": "pnpm build && node ./e2e/run.cjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e:live": "pnpm build && node ./e2e/run-live.cjs"
  },
  "dependencies": {
    "@branchline/git-utils": "workspace:*",
    "@branchline/shared-events": "workspace:*",
    "@branchline/shared-types": "workspace:*",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "glob": "^11.0.3",
    "mocha": "^11.7.2",
    "@types/vscode": "^1.98.0"
  }
}
